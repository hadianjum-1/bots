# ============================================
# Bot Backend Environment Configuration
# ============================================

# MongoDB Connection String
# Get from: https://www.mongodb.com/cloud/atlas
MONGODB_URL=mongodb+srv://username:password@cluster0.abc123.mongodb.net/dbname?retryWrites=true&w=majority

# Groq API Key (Free AI Model)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email (SMTP) Configuration
# For Gmail: Use App Password (not regular password)
# Enable 2FA and generate app password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=noreply@yourbusiness.com

# Server Configuration
PORT=3000
NODE_ENV=development

# Widget Base URL (where clients embed the script from)
# Change to your actual domain in production
WIDGET_BASE_URL=http://localhost:3000/api
